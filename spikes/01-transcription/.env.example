# Caminho para o JSON da service account com permissão roles/speech.client
# e roles/storage.objectAdmin no bucket abaixo.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ID do projeto GCP descartável deste spike.
GCP_PROJECT_ID=consulta-ia-spikes

# Bucket em southamerica-east1 para hospedar áudio durante a transcrição.
GCS_BUCKET=consulta-ia-spike-01-audio

# ── Tier 1 Cloud Providers ──────────────────────────────────────────────────
# ElevenLabs Scribe v2: https://elevenlabs.io (Settings → API Keys)
ELEVENLABS_API_KEY=

# Deepgram Nova-3: https://console.deepgram.com (API Keys)
DEEPGRAM_API_KEY=

# Cohere Transcribe: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ── Cloudflare Workers AI ────────────────────────────────────────────────────
# Account ID: Cloudflare dashboard → lado direito da página inicial
CF_ACCOUNT_ID=

# API Token com permissão "Workers AI (Write)":
# My Profile → API Tokens → Create Token → Workers AI template
CF_API_TOKEN=
