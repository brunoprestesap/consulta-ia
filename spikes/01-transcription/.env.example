# Caminho para o JSON da service account com permissão roles/speech.client
# e roles/storage.objectAdmin no bucket abaixo.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ID do projeto GCP descartável deste spike.
GCP_PROJECT_ID=consulta-ia-spikes

# Bucket em southamerica-east1 para hospedar áudio durante a transcrição.
GCS_BUCKET=consulta-ia-spike-01-audio
